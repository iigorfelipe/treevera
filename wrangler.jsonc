{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "treevera",
  "main": "worker.ts",
  "compatibility_date": "2025-04-01",
  "workers_dev": false,
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  }
}
